{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": ["${mod_authors}"],
  "contact": {
    "sources": "https://github.com/JustMili0/SulfurCubed",
    "issues": "https://github.com/JustMili0/SulfurCubed/issues",
    "homepage": "https://modrinth.com/mod/sulfur-cubed"
  },
  "license": "${mod_license}",
  "icon": "icon.png",
